<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8" />
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0 32px 32px;
            color: #222;
            font-size: 14px;
        }

        header {
            padding: 24px 0 16px;
            border-bottom: 2px solid #999;
            margin-bottom: 24px;
        }

        header h1 {
            margin: 0;
            font-size: 26px;
        }

        .section {
            margin-bottom: 24px;
        }

        .section h2 {
            margin: 0 0 12px;
            font-size: 18px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th,
        td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
            vertical-align: top;
        }

        th {
            width: 30%;
            background: #f3f3f3;
        }

        .image-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .image-card {
            width: 220px;
        }

        .image-card img {
            width: 100%;
            height: 160px;
            object-fit: cover;
            border: 1px solid #ccc;
        }

        .image-card p {
            margin: 6px 0 0;
            font-size: 12px;
            word-break: break-all;
        }

        Image grid ----- */ .image-grid {
            margin-top: 15px;
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            justify-content: flex-start;
        }

        .image-grid img {
            width: 150px;
            height: 150px;
            object-fit: cover;
            border: 1px solid #ddd;
            border-radius: 6px;
        }

        footer {
            position: fixed;
            bottom: 20px;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 12px;
            color: #777;
        }
    </style>
</head>

<body>
    <header>
        <h1>Prüfbericht</h1>
    </header>

    <div class="section">
        <h2>Berichtsdetails</h2>
        <table>
            <tr>
                <th>Titel</th>
                <td>
                    <%= report.title %>
                </td>
            </tr>
            <tr>
                <th>Beschreibung</th>
                <td>
                    <%= report.description || "Keine Beschreibung" %>
                </td>
            </tr>
            <tr>
                <th>Status</th>
                <td>
                    <%= report.status==="DEFECT" ? "Defekt" : "OK" %>
                </td>
            </tr>
            <tr>
                <th>Lieferant</th>
                <td>
                    <%= supplier.title %>
                </td>
            </tr>
            <tr>
                <th>Erstellt von</th>
                <td>
                    <%= report.createdByEmail || "" %>
                </td>
            </tr>
            <tr>
                <th>Erstellt am</th>
                <td>
                    <%= report.createdAt ? new Date(report.createdAt).toLocaleString("de-DE") : "" %>
                </td>
            </tr>

        </table>
    </div>




    <% if (report.images && Array.isArray(report.images) && report.images.length) { %>
        <% report.images.slice(0, 6).forEach(function (imgPath) { const fullSrc=imgPath.startsWith("http") ? imgPath :
            baseUrl.replace(/\/$/, "" ) + imgPath; // imgPath is "/uploads/..." %>
            <img src="<%= fullSrc %>" alt="Report Image" />
            <% }); %>
                <% } else { %>
                    <% for (let i=1; i <=6; i++) { %>
                        <img src="https://via.placeholder.com/150?text=Beispiel+Bild+<%= i %>"
                            alt="Beispiel Bild <%= i %>" />
                        <% } %>
                            <% } %>

                                <footer>
                                    Erstellt am <%= new Date().toLocaleString("de-DE") %>
                                </footer>
</body>

</html>